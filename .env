DATABASE_URL=postgresql://postgres:postgres@localhost:5432/access_control_db
SECRET_KEY=your-secret-key-32-chars-minimum-change-in-production
DEFAULT_ADMIN_PASSWORD=change-me-to-secure-password-8-chars-minimum
DECISION_THRESHOLD_GRANT=0.3
DECISION_THRESHOLD_DENY=0.7
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
RETRAIN_FREQUENCY_DAYS=40
RETRAIN_MODE=production
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=7

# Redis Cache Configuration
REDIS_CACHE_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
