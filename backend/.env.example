# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/access_control_db

# Security
SECRET_KEY=change-me-in-production-use-strong-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# MFA Configuration
TOTP_ISSUER=RaptorX

# Brute-force Protection
LOGIN_ATTEMPT_WINDOW_MINUTES=15
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# ML Model Paths
ML_MODEL_PATH=./app/ml/model.pkl
AUTOENCODER_MODEL_PATH=./app/ml/autoencoder.pkl

# Decision Thresholds
DECISION_THRESHOLD_GRANT=0.3
DECISION_THRESHOLD_DENY=0.7

# CORS Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# mTLS Configuration (optional)
MTLS_ENABLED=false
MTLS_TRUSTED_PROXY_IPS=127.0.0.1
