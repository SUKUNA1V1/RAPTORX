# RaptorX Environment Configuration Template
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/raptorx

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================

# JWT Secret Key (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=your-secret-key-here-minimum-32-characters-long

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin Credentials (REQUIRED - generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
# SECURITY: Change this immediately after first login!
DEFAULT_ADMIN_PASSWORD=change_me_to_a_strong_password_min_8_chars

# ============================================================================
# SECURITY SETTINGS
# ============================================================================

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Maximum failed login attempts before lockout
MAX_LOGIN_ATTEMPTS=5

# Lockout duration in minutes
LOCKOUT_DURATION_MINUTES=30

# ============================================================================
# ML MODEL CONFIGURATION
# ============================================================================

# Decision Thresholds for access decisions
DECISION_THRESHOLD_GRANT=0.30
DECISION_THRESHOLD_DENY=0.70

# Auto-Retrain Configuration
RETRAIN_FREQUENCY_DAYS=40
RETRAIN_MODE=false

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Debug mode (set to false in production)
DEBUG=true

# ============================================================================
# OPTIONAL: ADVANCED SETTINGS
# ============================================================================

# Database connection pool size
DB_POOL_SIZE=10
DB_POOL_RECYCLE=3600

# Redis Cache Configuration
REDIS_CACHE_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# API Server settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Cache settings (if implementing Redis)
# REDIS_URL=redis://localhost:6379/0

# Email settings (for notifications)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-email-password

# ============================================================================
# DO NOT EDIT BELOW THIS LINE
# ============================================================================
# These are defaults that should work for development

# Feature engineering mode (internal use)
RETRAIN_MODE=false

# WebSocket configuration
WS_HEARTBEAT_INTERVAL=30
WS_RECONNECT_TIMEOUT=5
