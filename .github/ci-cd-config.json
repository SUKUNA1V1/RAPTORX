{
  "version": "1.0",
  "name": "RAPTORX CI/CD Pipeline Configuration",
  "description": "Automated model retuning and deployment pipeline",
  
  "workflows": {
    "retune_thresholds": {
      "file": ".github/workflows/retune-thresholds.yml",
      "purpose": "Automatically retune anomaly detection thresholds",
      "triggers": {
        "schedule": "0 2 * * 0",
        "schedule_description": "Every Sunday at 2 AM UTC",
        "manual": "workflow_dispatch",
        "inputs": {
          "validate_only": {
            "description": "Only validate, do not update models",
            "type": "boolean",
            "default": false
          }
        }
      },
      "environment": {
        "python_version": "3.13",
        "timeout_minutes": 30,
        "runner": "ubuntu-latest"
      },
      "success_criteria": {
        "f1_score_min": 0.70,
        "f1_score_max": 0.95,
        "no_errors": true,
        "artifacts_generated": true
      },
      "outputs": {
        "updated_models": "Models updated if F1 in range",
        "retune_logs": "Full execution logs",
        "retune_results_json": "Structured results with metrics"
      }
    },
    
    "model_validation": {
      "file": ".github/workflows/model-validation.yml",
      "purpose": "Validate models after code changes",
      "triggers": {
        "push": {
          "paths": [
            "decision_engine.py",
            "train_isolation_forest.py",
            "train_autoencoder.py",
            "retune_threshold.py",
            "backend/app/services/decision_engine.py",
            ".github/workflows/model-validation.yml"
          ]
        },
        "pull_request": {
          "paths": [
            "decision_engine.py",
            "train_isolation_forest.py",
            "train_autoencoder.py",
            "retune_threshold.py",
            "backend/app/services/decision_engine.py"
          ]
        }
      },
      "matrix": {
        "python_version": ["3.11", "3.13"],
        "runs_on": "ubuntu-latest"
      },
      "checks": [
        "Linting (pylint)",
        "Type checking (mypy)",
        "Unit tests (pytest)",
        "Engine functionality",
        "Artifact validation",
        "Threshold range checks",
        "Thread safety (5 concurrent)"
      ]
    },
    
    "deploy_models": {
      "file": ".github/workflows/deploy-models.yml",
      "purpose": "Deploy validated models to staging/production",
      "triggers": {
        "workflow_run": "retune-thresholds success",
        "manual": "workflow_dispatch with environment selection"
      },
      "environments": {
        "staging": {
          "automatic": true,
          "after": "successful retuning"
        },
        "production": {
          "manual": true,
          "requires_approval": true
        }
      },
      "pre_deployment_checks": [
        "Artifact verification",
        "Model integrity validation",
        "Checksum verification",
        "Size checks"
      ]
    }
  },
  
  "scripts": {
    "ci_pipelines_sh": {
      "file": "ci_pipelines.sh",
      "description": "Local CI/CD pipeline helper script",
      "commands": {
        "retune": "Run threshold retuning locally",
        "validate": "Run CI/CD retuning with structured output",
        "test": "Run model validation tests",
        "logs": "Show recent CI/CD logs",
        "status": "Check workflow status",
        "help": "Show help"
      }
    },
    "ci_retune_threshold_py": {
      "file": "ci_retune_threshold.py",
      "description": "CI/CD-friendly threshold retuning wrapper",
      "features": [
        "Structured JSON output",
        "Error handling and reporting",
        "Model validation",
        "Automatic model updates"
      ],
      "output": "retune_results.json with detailed metrics"
    }
  },
  
  "environment_setup": {
    "python_version": "3.13",
    "required_packages": [
      "numpy",
      "pandas",
      "scikit-learn",
      "tensorflow==2.20.0",
      "joblib",
      "pytest",
      "mypy",
      "pylint",
      "psutil"
    ],
    "data_requirements": {
      "validation_data": "data/processed/val_scaled.csv",
      "test_data": "data/processed/test_scaled.csv",
      "features": 13
    },
    "model_artifacts": {
      "isolation_forest": "ml/models/isolation_forest.pkl",
      "autoencoder": "ml/models/autoencoder.pkl",
      "ensemble_config": "ml/models/ensemble_config.pkl",
      "model_registry": "ml/models/model_registry.json"
    }
  },
  
  "thresholds": {
    "f1_score": {
      "excellent": {
        "min": 0.85,
        "max": 0.92,
        "verdict": "Production-ready, deploy immediately"
      },
      "good": {
        "min": 0.80,
        "max": 0.85,
        "verdict": "Acceptable, deploy with monitoring"
      },
      "moderate": {
        "min": 0.70,
        "max": 0.80,
        "verdict": "Needs improvement, block production"
      },
      "needs_work": {
        "max": 0.70,
        "verdict": "Below threshold, investigate issue"
      }
    },
    "threshold_value": {
      "min": 0.0,
      "max": 1.0,
      "valid_range": [0.0, 1.0]
    },
    "overfitting_warning": {
      "f1_score_above": 0.95,
      "message": "Possible data leakage or too-easy dataset"
    }
  },
  
  "artifacts": {
    "retention_days": 30,
    "types": [
      {
        "name": "updated-models",
        "description": "Updated model pickle files",
        "files": [
          "isolation_forest.pkl",
          "ensemble_config.pkl",
          "model_registry.json"
        ]
      },
      {
        "name": "retune-logs",
        "description": "Full execution logs",
        "files": ["retune_output.log"]
      },
      {
        "name": "validation-report",
        "description": "Model validation test results",
        "files": [".coverage", "htmlcov/"]
      }
    ]
  },
  
  "scheduling": {
    "retune_frequency": "weekly",
    "default_schedule": "0 2 * * 0",
    "timezone": "UTC",
    "description": "Sunday at 2:00 AM UTC",
    "adjustable": true,
    "cron_format": "minute hour day-of-month month day-of-week"
  },
  
  "monitoring": {
    "metrics_tracked": [
      "F1 score",
      "Precision",
      "Recall",
      "AUC-ROC",
      "Validation time",
      "Model size",
      "Threshold value"
    ],
    "alerts": [
      "Failed retuning runs",
      "F1 score out of range",
      "Performance degradation",
      "Model artifact issues"
    ],
    "dashboard": "/performance"
  },
  
  "deployment": {
    "staging": {
      "automatic_after": "successful_validation",
      "rollback_enabled": true,
      "health_checks": [
        "Model integrity",
        "Threshold validation",
        "Performance tests"
      ]
    },
    "production": {
      "requires_manual_approval": true,
      "requires_pullrequest": false,
      "backup_previous": true,
      "health_checks": [
        "All staging checks",
        "API integration test",
        "Load test"
      ],
      "monitoring_period_minutes": 30
    }
  },
  
  "documentation": {
    "main_guide": "CI_CD_GUIDE.md",
    "quick_start": "ci_pipelines.sh",
    "configuration": ".github/workflows/",
    "api_docs": "backend/app/routes/stats.py"
  }
}
